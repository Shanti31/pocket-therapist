# ====================================================
# Pocket Therapist - Variables d'environnement
# ====================================================
# Copie ce fichier en .env et remplis tes clés réelles
# cp .env.example .env
#
# ⚠️  IMPORTANT: Ne commit JAMAIS le fichier .env
#     Ajoute-le à .gitignore
# ====================================================

# ====================================================
# Backend Configuration
# ====================================================

# Supabase URL (from Supabase Dashboard)
SUPABASE_URL=https://xxxxx.supabase.co

# Supabase Anon Key (Public, safe to expose)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (KEEP SECRET! Only use server-side)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# FastAPI Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
BACKEND_RELOAD=true

# ====================================================
# Frontend Configuration
# ====================================================

# Next.js API URL (change for production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Next.js Environment
NODE_ENV=development
FRONTEND_PORT=3000

# ====================================================
# Docker Configuration
# ====================================================

# Docker Compose
COMPOSE_PROJECT_NAME=pocket-therapist
COMPOSE_FILE=docker-compose.yml

# ====================================================
# Database Configuration (Supabase)
# ====================================================

# Database URL (generated by Supabase)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ====================================================
# Production Configuration (à définir lors du déploiement)
# ====================================================

# Domain pour CORS en production
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Environment Mode
ENVIRONMENT=development
# production | staging | development

# Debug Mode
DEBUG=false

# ====================================================
# Notes
# ====================================================
# 1. Crée ton compte Supabase: https://app.supabase.com
# 2. Crée un nouveau projet PostgreSQL
# 3. Copie les clés depuis Supabase Dashboard → Settings → API
# 4. Remplis les valeurs ci-dessus
# 5. Lance: docker-compose up
